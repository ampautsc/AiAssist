{
  "format_version": "1.21.40",
  "minecraft:block": {
    "description": {
      "identifier": "monarch:milkweed",
      "menu_category": {
        "category": "nature"
      },
      "states": {
        "monarch:growth_stage": [0, 1, 2]
      }
    },
    "components": {
      "minecraft:custom_components": ["monarch:growable"],
      "minecraft:geometry": "minecraft:geometry.cross",
      "minecraft:light_dampening": 0,
      "minecraft:destructible_by_mining": {
        "seconds_to_destroy": 0.5
      },
      "minecraft:destructible_by_explosion": {
        "explosion_resistance": 0
      },
      "minecraft:material_instances": {
        "*": {
          "texture": "milkweed_stage_0",
          "render_method": "alpha_test"
        }
      },
      "minecraft:collision_box": false,
      "minecraft:selection_box": {
        "origin": [-6, 0, -6],
        "size": [12, 16, 12]
      },
      "minecraft:placement_filter": {
        "conditions": [
          {
            "allowed_faces": ["up"],
            "block_filter": ["minecraft:grass_block", "minecraft:dirt", "minecraft:farmland"]
          }
        ]
      },
      "minecraft:loot": "loot_tables/blocks/milkweed_mature.json"
    },
    "permutations": [
      {
        "condition": "q.block_state('monarch:growth_stage') == 0",
        "components": {
          "minecraft:material_instances": {
            "*": {
              "texture": "milkweed_stage_0",
              "render_method": "alpha_test"
            }
          }
        }
      },
      {
        "condition": "q.block_state('monarch:growth_stage') == 1",
        "components": {
          "minecraft:material_instances": {
            "*": {
              "texture": "milkweed_stage_1",
              "render_method": "alpha_test"
            }
          }
        }
      },
      {
        "condition": "q.block_state('monarch:growth_stage') == 2",
        "components": {
          "minecraft:material_instances": {
            "*": {
              "texture": "milkweed_stage_2",
              "render_method": "alpha_test"
            }
          }
        }
      }
    ]
  }
}
