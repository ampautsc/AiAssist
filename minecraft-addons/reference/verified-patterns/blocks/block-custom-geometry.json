{
  "_comment": "Block with custom geometry model",
  "_important": "Geometry must be defined in resource pack models/blocks/ folder",
  "_texture_note": "All textures referenced must exist in terrain_texture.json",
  
  "format_version": "1.21.40",
  "minecraft:block": {
    "description": {
      "identifier": "namespace:custom_block",
      "menu_category": {
        "category": "items"
      },
      "states": {
        "namespace:active": [false, true]
      }
    },
    "components": {
      "minecraft:custom_components": ["namespace:block_behavior"],
      "minecraft:geometry": "geometry.namespace.custom_block",
      "minecraft:light_dampening": 0,
      "minecraft:light_emission": 0,
      "minecraft:destructible_by_mining": {
        "seconds_to_destroy": 0.5
      },
      "minecraft:collision_box": {
        "origin": [-4, 0, -4],
        "size": [8, 10, 8]
      },
      "minecraft:selection_box": {
        "origin": [-4, 0, -4],
        "size": [8, 10, 8]
      },
      "minecraft:material_instances": {
        "_comment": "Single texture for all faces - safest approach",
        "*": {
          "texture": "block_texture_off",
          "render_method": "opaque"
        }
      },
      "minecraft:placement_filter": {
        "conditions": [
          {
            "allowed_faces": ["up"]
          }
        ]
      },
      "minecraft:loot": "loot_tables/blocks/custom_block.json"
    },
    "permutations": [
      {
        "condition": "q.block_state('namespace:active') == true",
        "components": {
          "minecraft:light_emission": 14,
          "minecraft:material_instances": {
            "*": {
              "texture": "block_texture_on",
              "render_method": "opaque",
              "face_dimming": false,
              "ambient_occlusion": false
            }
          }
        }
      }
    ]
  }
}
