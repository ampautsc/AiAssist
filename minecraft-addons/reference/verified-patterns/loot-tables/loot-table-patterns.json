{
  "_comment": "Loot table patterns for blocks and entities",
  
  "block_drop_self": {
    "_comment": "Block drops itself when broken",
    "pools": [
      {
        "rolls": 1,
        "entries": [
          {
            "type": "item",
            "name": "namespace:block_name"
          }
        ]
      }
    ]
  },
  
  "block_drop_item": {
    "_comment": "Block drops a different item",
    "pools": [
      {
        "rolls": 1,
        "entries": [
          {
            "type": "item",
            "name": "namespace:my_item",
            "functions": [
              {
                "function": "set_count",
                "count": {
                  "min": 1,
                  "max": 3
                }
              }
            ]
          }
        ]
      }
    ]
  },
  
  "conditional_drop": {
    "_comment": "Drop based on conditions",
    "pools": [
      {
        "rolls": 1,
        "entries": [
          {
            "type": "item",
            "name": "namespace:seeds",
            "weight": 1
          }
        ],
        "conditions": [
          {
            "condition": "random_chance",
            "chance": 0.25
          }
        ]
      }
    ]
  },
  
  "empty_loot": {
    "_comment": "Block drops nothing",
    "pools": []
  }
}
