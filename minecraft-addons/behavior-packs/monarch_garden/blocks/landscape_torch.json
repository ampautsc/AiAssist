      },
      "minecraft:placement_filter": {
        "conditions": [
          {
            "allowed_faces": ["up"]
          }
        ]
      },
      "minecraft:loot": "loot_tables/blocks/landscape_torch.json"
    },
    "permutations": [
      {
        "condition": "q.block_state('monarch:lit') == true",
