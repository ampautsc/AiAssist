{
  "format_version": "1.21.40",
  "minecraft:block": {
    "description": {
      "identifier": "monarch:landscape_torch",
      "menu_category": {
        "category": "items",
        "group": "itemGroup.name.torch"
      },
      "states": {
        "monarch:lit": [false, true]
      }
    },
    "components": {
