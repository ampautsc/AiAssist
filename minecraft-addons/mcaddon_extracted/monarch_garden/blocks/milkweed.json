{
  "format_version": "1.20.50",
  "minecraft:block": {
    "description": {
      "identifier": "monarch:milkweed",
      "menu_category": {
        "category": "nature"
      },
      "states": {
        "monarch:growth_stage": {
          "values": { "min": 0, "max": 2 }
        }
      }
    },
    "components": {
      "minecraft:light_dampening": 0,
      "minecraft:destructible_by_mining": {
        "seconds_to_destroy": 0.5
      },
      "minecraft:destructible_by_explosion": {
        "explosion_resistance": 0
      },
      "minecraft:geometry": "geometry.crop",
      "minecraft:material_instances": {
        "*": {
          "texture": "milkweed",
          "render_method": "alpha_test"
        }
      },
      "minecraft:collision_box": false,
      "minecraft:selection_box": {
        "origin": [-6, 0, -6],
        "size": [12, 16, 12]
      },
      "minecraft:placement_filter": {
        "conditions": [
          {
            "allowed_faces": ["up"],
            "block_filter": ["minecraft:grass", "minecraft:dirt", "minecraft:farmland"]
          }
        ]
      },
      "minecraft:random_ticking": {
        "on_tick": {
          "event": "monarch:grow"
        }
      }
    },
    "permutations": [
      {
        "condition": "query.block_state('monarch:growth_stage') == 0",
        "components": {
          "minecraft:selection_box": {
            "origin": [-6, 0, -6],
            "size": [12, 4, 12]
          }
        }
      },
      {
        "condition": "query.block_state('monarch:growth_stage') == 1",
        "components": {
          "minecraft:selection_box": {
            "origin": [-6, 0, -6],
            "size": [12, 10, 12]
          }
        }
      },
      {
        "condition": "query.block_state('monarch:growth_stage') == 2",
        "components": {
          "minecraft:selection_box": {
            "origin": [-6, 0, -6],
            "size": [12, 16, 12]
          },
          "minecraft:loot": "loot_tables/blocks/milkweed_mature.json"
        }
      }
    ],
    "events": {
      "monarch:grow": {
        "set_block_state": {
          "monarch:growth_stage": "query.block_state('monarch:growth_stage') < 2 ? query.block_state('monarch:growth_stage') + 1 : 2"
        }
      }
    }
  }
}
